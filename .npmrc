# next-auth@5.0.0-beta.30 declares a peerOptional on @simplewebauthn/browser
# ^9.0.1. We use v13 (matches @simplewebauthn/server v13 — they're versioned
# together upstream). The peer is optional and never imported by next-auth's
# runtime; relaxing the resolver here is safer than pinning back to v9, which
# would force a rewrite of the v13-style call sites.
legacy-peer-deps=true
